# ============ NETPLAN ENVIRONMENT CONFIGURATION ============
# Copy this file to .env and fill in your actual values
# .env.example is safe to commit to Git, .env is NOT

# ============ SERVER (Backend) ============
# Database path (e.g., TrueNAS mount)
DB_PATH=/Volumes/app-data/db/netplan.db

# Server port
PORT=3030

# Server path in compiled app
SERVER_PATH=server

# ============ FRONTEND (Renderer Process) ============
# API URL for Electron production (Vite prefix required)
VITE_API_URL=http://localhost:3030/api

# Placeholder names for UI (replaces "Marl, Herten")
VITE_PROJECT_PLACEHOLDER_NAME=Projekt A
VITE_LOCATION_PLACEHOLDER_NAME=Standort

# Logo path for header (optional for custom branding)
VITE_LOGO_PATH=/netplan_logo.jpeg