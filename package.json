{
  "name": "netplan",
  "private": true,
  "version": "1.1.2",
  "type": "module",
  "main": "electron/main.js",
  "author": "Divital",
  "description": "Netplan - Netzwerkplanungssoftware",
  "build": {
    "appId": "com.divital.netplan",
    "productName": "Netplan",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "electron",
      "package.json"
    ],
    "asarUnpack": [
      "server/**/*"
    ],
    "extraMetadata": {
      "DB_PATH": "/Volumes/app-data/db/netplan.db",
      "PORT": "3030",
      "SERVER_PATH": "server",
      "VITE_LOGO_PATH": "divital_logo.png",
      "VITE_PROJECT_PLACEHOLDER_NAME": "Netplan",
      "VITE_LOCATION_PLACEHOLDER_NAME": "Ihr Standort",
      "VITE_API_URL": "http://localhost:3030/api"
    },
    "extraResources": [
      {
        "from": "server",
        "to": "server",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "server": "node server/index.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run server\"",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "electron": "NODE_ENV=development electron electron/main.js",
    "electron:dev": "concurrently \"npm run dev\" \"electron electron/main.js\"",
    "build:mac": "npm run build && electron-builder --mac",
    "build:win": "npm run build && electron-builder --win",
    "pack": "electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "postinstall": "npx electron-builder install-app-deps"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "better-sqlite3": "^12.6.2",
    "body-parser": "^2.2.2",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "fs-extra": "^11.3.4",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.4",
    "reactflow": "^11.11.4",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
